{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "The Sieve",
  "version": "0.2.0",
  "identifier": "com.thesieve.desktop",
  "build": {
    "frontendDist": "ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
